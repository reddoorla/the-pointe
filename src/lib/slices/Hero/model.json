{
  "id": "hero",
  "type": "SharedSlice",
  "name": "Hero",
  "description": "Full-bleed hero with background media and heading/CTA",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Background image with heading, body, and CTA",
      "imageUrl": "",
      "primary": {
        "heading": {
          "type": "StructuredText",
          "config": { "label": "heading", "single": "heading1,heading2" }
        },
        "body": {
          "type": "StructuredText",
          "config": {
            "label": "body",
            "multi": "paragraph,strong,em,hyperlink"
          }
        },
        "background_image": {
          "type": "Image",
          "config": {
            "label": "background_image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "cta_label": { "type": "Text", "config": { "label": "cta_label" } },
        "cta_link": {
          "type": "Link",
          "config": { "label": "cta_link", "allowTargetBlank": true }
        }
      },
      "items": {}
    }
  ]
}
